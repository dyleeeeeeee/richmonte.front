# InvBank — Frontend environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# ─── Core banking backend (richemonte.backend / Quart + Supabase) ──────────
# Local dev default: http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# ─── Mock mode (test the UI without a running backend) ─────────────────────
# Set USE_MOCK=1 to always use the in-browser fake backend (lib/mockApi.ts).
# Set MOCK_FALLBACK=1 to auto-switch to mock only when the real backend is
# unreachable (useful for demos/CI).
#
# Demo accounts (mock mode):
#   demo@invbank.us   / password123  (PIN 123456)
#   admin@invbank.us  / admin123     (PIN 000000, admin role)
#
# Runtime toggle in the browser console:
#   window.invbankMock.enable()    // persists + reloads
#   window.invbankMock.disable()
#   window.invbankMock.reset()     // wipes the fake DB
NEXT_PUBLIC_USE_MOCK=1
NEXT_PUBLIC_MOCK_FALLBACK=1

# ─── Google Maps (optional — BranchMap component) ──────────────────────────
# https://console.cloud.google.com/apis/credentials → enable "Maps JavaScript API"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Trade module — investing portal (/dashboard/trade) ────────────────────
# Market data source (Binance public API). No key required for read-only klines.
NEXT_PUBLIC_MARKET_DATA_URL=https://api.binance.com

# Optional: Gemini AI (for trade-idea summarization / chat).
# Only include if you want the AI advisor on the trading desk active.
# https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# Optional: Polygon.io for US equities real-time quotes (free tier available)
# https://polygon.io/dashboard/api-keys
NEXT_PUBLIC_POLYGON_API_KEY=

# Optional: Finnhub for news headlines on the trading desk
# https://finnhub.io/dashboard
NEXT_PUBLIC_FINNHUB_API_KEY=

# ─── Observability (optional) ──────────────────────────────────────────────
# Sentry DSN, PostHog, etc.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=

# NOTE: `NEXT_PUBLIC_` prefix exposes the value to the browser bundle.
#       Secrets without that prefix are server-only.
